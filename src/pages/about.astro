---
import Layout from "../layouts/Layout.astro";
import Title1 from "../components/mdx/typography/Title1.astro";
import Title2 from "../components/mdx/typography/Title2.astro";
import SmallCaps from "../components/mdx/typography/SmallCaps.astro";
import UnderlineHoverLink from "../components/mdx/UnderlineHoverLink.astro";
import PageWrapper from "../components/layouts/PageWrapper.astro";
import { Image } from "astro:assets";
import Headshot from "../images/general/headshot-fk.png";
// import Stripe2 from "../images/general/Stripe2_1000.jpg";
// import Scarf from "../images/general/Scarf_1000.jpg";
// import Brown from "../images/general/Brown_1000.jpg";

const photoSources = [Headshot];
---

<script>
  const photos = document.querySelectorAll(".random-photo") as NodeListOf<HTMLElement>;
  const randomIndex = Math.floor(Math.random() * photos.length);

  // Hide all photos except the random one
  photos.forEach((photo, index) => {
    if (index === randomIndex) {
      photo.style.display = "block";
    }
  });
</script>

<Layout
  title="About Josef Scarantino"
  desc="Systems thinker, community-builder, and accidental founder."
>
  <PageWrapper>
    <div class="header-section">
      <SmallCaps>About</SmallCaps>
      <Title1>Josef M. Scarantino</Title1>
      <Title2>Systems thinker, community-builder, and accidental founder.</Title2>
    </div>
    <div class="styled-main">
      <section class="intro">
        <div>
          <SmallCaps>In a nutshell</SmallCaps>
          <p>
            As a social innovation strategist, my work helps to design impactful, collaborative
            experiences where people and communities can fully participate and thrive. I'm also a
            serial entrepreneur and established founder coach with nearly 25 years of experience
            building entrepreneurial communities, startup ecosystems, and next generation impact
            leaders.
          </p>
          <p>
            My work has reached thousands of students, entrepreneurs, and innovators across more
            than 50 countries and touched a wide variety of sectors, including workforce
            development, higher education, nonprofit, government, corporate innovation, and many
            others.
          </p>
          <p>
            I'm currently building the transformation economy at <UnderlineHoverLink
              href="https://forwardkind.com"
            >
              Forwardkind,</UnderlineHoverLink
            >exploring how a shared-ownership cooperative model can contribute to cultivating
            collective human potential.
          </p>
          <p>Here's what I've been up to for the last 20+ years:</p>
          <div class="timeline">
            <div class="timeline-item">
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <div class="timeline-role-company">
                  Founder & President at <UnderlineHoverLink href="https://forwardkind.com"
                    >Forwardkind Cooperative</UnderlineHoverLink
                  >
                </div>
                <div class="timeline-year">2025 - Present</div>
                <div class="timeline-description">
                  Forwardkind is building a shared-ownership, regenerative ecosystem that multiplies
                  human potential — expanding access to transformational work and amplifying the
                  collective impact of purpose-driven people.
                </div>
              </div>
            </div>

            <div class="timeline-item">
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <div class="timeline-role-company">
                  Founder at <UnderlineHoverLink href="https://wckdlabs.com/"
                    >WCKD Labs</UnderlineHoverLink
                  >
                </div>
                <div class="timeline-year">2025 - Present</div>
                <div class="timeline-description">Coming soon</div>
              </div>
            </div>

            <div class="timeline-item">
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <div class="timeline-role-company">
                  Founder at <UnderlineHoverLink href="https://seedscalepartners.com/"
                    >Seed Scale Partners</UnderlineHoverLink
                  >
                </div>
                <div class="timeline-year">2024 - Present</div>
                <div class="timeline-description">
                  Seed Scale Partners delivers program design & management, ecosystem mapping,
                  founder workshops, hackathons & pitch events, among other offerings. Most recent
                  work is the <UnderlineHoverLink href="https://rcedp.org/hca_lp"
                    >High Country Accelerator</UnderlineHoverLink
                  > in northwest Colorado.
                </div>
              </div>
            </div>

            <div class="timeline-item">
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <div class="timeline-role-company">
                  Program Advisor at <UnderlineHoverLink href="https://startupcolorado.org"
                    >Startup Colorado</UnderlineHoverLink
                  >
                </div>
                <div class="timeline-year">2024</div>
                <div class="timeline-description">
                  Startup Colorado's mission is to demonstrate that rural entrepreneurship will
                  ignite a culture of potential.
                </div>
              </div>
            </div>

            <div class="timeline-item">
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <div class="timeline-role-company">
                  Head of Programs at <UnderlineHoverLink href="https://allraise.org"
                    >All Raise</UnderlineHoverLink
                  >
                </div>
                <div class="timeline-year">2022 - 2023</div>
                <div class="timeline-description">
                  All Raise is on a mission to accelerate the success of women and
                  nonbinary investors, reshaping culture, capital flows, and decision-making power
                  within venture capital.
                </div>
              </div>
            </div>

            <div class="timeline-item">
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <div class="timeline-role-company">
                  Program Manager at <UnderlineHoverLink href="https://www.hubspot.com/ventures"
                    >HubSpot Ventures</UnderlineHoverLink
                  >
                </div>
                <div class="timeline-year">2022</div>
                <div class="timeline-description">
                  HubSpot Ventures invests in early- and growth-stage software companies with the
                  potential to deliver unique value to HubSpot's customer base.
                </div>
              </div>
            </div>

            <div class="timeline-item">
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <div class="timeline-role-company">
                  Senior Program Manager at <UnderlineHoverLink href="https://techstars.com"
                    >Techstars</UnderlineHoverLink
                  >
                </div>
                <div class="timeline-year">2019 - 2022</div>
                <div class="timeline-description">
                  Founded in 2006, Techstars is on a mission to invest in startups to enable more
                  capital to flow to more entrepreneurs around the world in order to deliver
                  exceptional returns to investors. Techstars does this by operating accelerator programs
                  and venture capital funds, as well as by connecting startups, investors,
                  corporations, and cities to help build thriving startup communities.
                </div>
              </div>
            </div>

            <div class="timeline-item">
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <div class="timeline-role-company">CEO & Co-Founder at EightTen</div>
                <div class="timeline-year">2016 - 2019</div>
                <div class="timeline-description">
                  EightTen was an edtech startup dedicated to increasing labor force participation
                  of people with disabilities through soft skills training.
                </div>
              </div>
            </div>

            <div class="timeline-item">
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <div class="timeline-role-company">
                  Director of Social Enterprise at Community Resource Center
                </div>
                <div class="timeline-year">2017 - 2018</div>
                <div class="timeline-description">
                  CRC creates opportunities, tools, and strategies to develop nonprofits and
                  community groups to strengthen Colorado.
                </div>
              </div>
            </div>

            <div class="timeline-item">
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <div class="timeline-role-company">
                  Director of Life Labs at United Cerebral Palsy
                </div>
                <div class="timeline-year">2012 - 2016</div>
                <div class="timeline-description">
                  Mission to promote the independence and inclusion of people with cerebral palsy,
                  intellectual, developmental, and other disabilities through a network of
                  affiliates and partnerships.
                </div>
              </div>
            </div>

            <div class="timeline-item">
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <div class="timeline-role-company">Founder at African Tech Network</div>
                <div class="timeline-year">2010</div>
                <div class="timeline-description">
                  African Tech Network (ATN) served African technologists through creating economic
                  opportunity, community, and continuing education.
                </div>
              </div>
            </div>

            <div class="timeline-item">
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <div class="timeline-role-company">Founder at webstartAfrica</div>
                <div class="timeline-year">2009</div>
                <div class="timeline-description">
                  Webstart Africa focused on increasing access to turn-key technology stacks for
                  emerging African entrepreneurs.
                </div>
              </div>
            </div>

            <div class="timeline-item">
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <div class="timeline-role-company">Creative Director at GovTrends</div>
                <div class="timeline-year">2006 - 2009</div>
                <div class="timeline-description">
                  GovTrends was a web development and design studio providing services to government
                  entities and representatives and Fortune 500 companies.
                </div>
              </div>
            </div>
          </div>
        </div>
        {
          photoSources.map((photo, index) => (
            <Image
              src={photo}
              alt="a photo of josef scarantino"
              width={1000 / 1.25}
              height={1000 / 1.25}
              style={`object-fit: contain; display: none;`}
              class="random-photo"
              id={`photo-${index}`}
            />
          ))
        }
      </section>
    </div>
  </PageWrapper>
</Layout>

<style>
  .header-section {
    margin: var(--space-m) auto 0;
  }
  .header-section :global(.small-caps) {
    margin-bottom: var(--space-3xs);
    color: var(--color-gray-600);
  }
  .header-section h1 {
    margin-bottom: var(--space-s);
  }
  .header-section h2 {
    color: var(--color-gray-800);
  }

  .styled-main {
    margin-top: var(--space-xs);
    padding: var(--space-xl) 0;
    width: 100%;
  }

  @media (max-width: 768px) {
    .styled-main {
      padding: var(--space-l) var(--space-xs);
    }
  }

  .styled-main img {
    border-radius: 4px;
  }

  .styled-main h2 {
    margin-bottom: var(--space-s);
  }

  .styled-main p {
    line-height: var(--leading-loose);
    max-width: 52ch;
  }

  .styled-main p:not(:last-of-type) {
    margin-bottom: var(--space-s);
  }

  .intro {
    display: grid;
    grid-template-columns: 4fr 3fr;
    gap: var(--space-xl);
    align-items: flex-start;
  }

  .intro :global(.small-caps):not(:first-of-type) {
    margin-top: var(--space-xl);
    color: var(--color-gray-900);
  }

  .intro :global(.small-caps)::before {
    content: "";
    display: inline-block;
    width: 25px;
    clear: both;
    height: 25px;
    margin-right: -1.5rem;
    background-image: url("/images/nut.svg");
    background-size: contain;
    background-repeat: no-repeat;
    position: relative;
    top: 4px;
    right: 2.25rem;
  }

  @media (max-width: 768px) {
    .intro {
      grid-template-columns: 1fr;
      gap: var(--space-m);
      flex-direction: column;
    }
  }

  .intro :global(.small-caps) {
    margin-bottom: 1.5rem;
  }

  /* Timeline Styles */
  .timeline {
    position: relative;
    max-width: 64ch;
    margin: var(--space-l) 0 var(--space-xl) 0;
    font-family: var(--font-sans);
  }

  /* Timeline line */
  .timeline::before {
    content: "";
    position: absolute;
    left: 8px;
    top: 18px;
    bottom: -90px;
    width: 2px;
    background: linear-gradient(to bottom, var(--color-gray-300) 75%, var(--color-cream) 90%);
  }

  .timeline-item {
    position: relative;
    margin-bottom: var(--space-l);
    padding-left: 2.5rem;
  }

  .timeline-item:last-child {
    margin-bottom: 0;
  }

  .timeline-marker {
    position: absolute;
    left: 0;
    top: 12px;
    width: 16px;
    height: 16px;
    background: var(--color-cream);
    border: 2px solid var(--color-gray-400);
    border-radius: 50%;
    z-index: 1;
  }

  .timeline-year {
    font-weight: 500;
    color: var(--color-gray-600);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.025em;
  }

  .timeline-role-company {
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    font-weight: 500;
    color: var(--color-gray-900);
    margin-bottom: var(--space-2xs);
    line-height: var(--leading-normal);
  }

  .timeline-description {
    color: var(--color-gray-700);
    line-height: var(--leading-base);
  }

  @media (max-width: 768px) {
    .timeline {
      margin-left: var(--space-2xs);
    }

    .timeline::before {
      top: 15px;
      bottom: calc(var(--space-l) + 15px);
    }

    .timeline-item {
      padding-left: var(--space-l);
    }

    .timeline-marker {
      width: 20px;
      height: 20px;
      top: 10px;
    }
  }
</style>
